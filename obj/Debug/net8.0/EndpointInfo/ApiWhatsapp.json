        "type": "object",
        "properties": {
          "numero": {
            "type": "integer",
            "format": "int32"
          },
          "prefijo": {
            "type": "integer",
            "format": "int32"
          },
          "nombre": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "name": "Authorization",
